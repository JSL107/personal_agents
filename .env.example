# 서버 포트 (기본값 3000). 로컬에 이미 상주 중인 다른 프로젝트 서비스(3000, 3001) 와 충돌 회피 위해 3002 로 분리.
PORT=3002

# Redis 연결 정보 (BullMQ — crawler 도메인)
# 포트는 docker-compose 의 redis 호스트 포트(6381)와 매칭. 타 프로젝트 Redis(6379/6380) 와 충돌 회피 목적.
REDIS_HOST=localhost
REDIS_PORT=6381

# PostgreSQL 연결 (Prisma + docker-compose)
# docker-compose.yml 은 이 값들을 environment 에 interpolation — 하드코딩된 credential 을 저장소에 두지 않기 위함.
# 자격증명/포트를 바꾸려면 여기 4개 + docker-compose.yml 을 함께 갱신. (비밀번호를 강하게 바꾸려면 DATABASE_URL 도 같이.)
POSTGRES_USER=idaeri
POSTGRES_PASSWORD=idaeri
POSTGRES_DB=idaeri
DATABASE_URL=postgresql://idaeri:idaeri@localhost:5434/idaeri?schema=public

# Slack 봇 (이대리 — Socket Mode).
# 3개 모두 설정된 경우에만 Slack 봇이 기동됨. 하나라도 비어 있으면 앱은 정상 부팅하되 Slack 기능만 비활성화.
# 발급 경로: https://api.slack.com/apps (Socket Mode On → App-Level Token scope=connections:write)
SLACK_BOT_TOKEN=
SLACK_APP_TOKEN=
SLACK_SIGNING_SECRET=

# GitHub Personal Access Token (classic, scope: repo + read:user).
# 미설정 시 GitHub 커넥터(`/today` evidence 자동 수집 등)는 호출 시 GITHUB_TOKEN_NOT_CONFIGURED 예외로 빠진다 — 앱 부팅에는 영향 없음.
# 발급 경로: https://github.com/settings/tokens
GITHUB_TOKEN=

# Notion integration token + 조회할 task DB ID 콤마 구분 리스트.
# 미설정 시 Notion 커넥터는 호출 시 NOTION_TOKEN_NOT_CONFIGURED 예외 — 앱 부팅 영향 없음.
# 발급 경로: https://www.notion.so/my-integrations (Internal type)
# DB ID: 페이지 URL 의 32자 hex (https://notion.so/.../<DB_ID>?v=...)
# DB 권한 부여: 각 DB 페이지 ... → Connections → integration 추가 (필수)
NOTION_TOKEN=
NOTION_TASK_DB_IDS=

# (선택) Claude CLI 모델 — 기본값 opus (기획서 §13 개발형 에이전트 = Claude Code Max).
# 구독 quota 를 아끼거나 응답 속도를 우선하려면 sonnet / haiku 로 override 가능.
# 영향 에이전트: BE (/plan-task), Code Reviewer (/review-pr).
CLAUDE_MODEL=opus

# (필수 — Notion 자동 기록을 쓸 때) "일일 회고" 용 별도 Notion DB.
# 미설정 시 /today /worklog 의 Notion append 는 skip (앱 부팅 영향 없음).
# ⚠️ task DB (NOTION_TASK_DB_IDS) 와 절대 겹치지 말 것 — self-authored day-page 가 task 로 되돌아와
#    다음 /today 의 prompt 에 누적 오염 (codex review bhtilxlpc P1).
# 동작: /today 는 "YYYY.MM.DD" page 를 찾거나 생성해 "Check in HH:MM" 섹션 append,
#       /worklog 는 같은 page 에 "Check Out HH:MM + KEEP-PROBLEM-TRY" 섹션 append.
# DB 요구 조건: title property 1개 (이름/Name/Title 무엇이든 OK — 자동 탐지).
NOTION_DAILY_PLAN_DATABASE_ID=

# 휴가 계산기 — 본인 입사일 (YYYY-MM-DD). 미설정 시 /휴가 비활성(명령 시 안내).
VACATION_HIRE_DATE=2024-01-15

# Resume Calibration Cron (Phase 4) — 주1회 이력서 보정 점검 DM
RESUME_CALIBRATION_OWNER_SLACK_USER_ID=
RESUME_CALIBRATION_TARGET=
RESUME_CALIBRATION_CRON=0 10 * * 1
RESUME_CALIBRATION_TIMEZONE=Asia/Seoul

# Job Application Nudge Cron (Phase 3) — 매일 마감 임박/팔로업 지난 지원 건 넛지 DM
JOB_APPLICATION_NUDGE_OWNER_SLACK_USER_ID=
JOB_APPLICATION_NUDGE_TARGET=
JOB_APPLICATION_NUDGE_CRON=0 9 * * *
JOB_APPLICATION_NUDGE_TIMEZONE=Asia/Seoul

# Autopilot — 워크데이 플레이북 자동 발화 게이트 (SP1: Daily Eval 19:00 KST PO_EVAL).
# 미설정 시 Autopilot 전체 비활성. (기존 DAILY_EVAL_* 대체)
AUTOPILOT_OWNER_SLACK_USER_ID=
AUTOPILOT_TARGET=
AUTOPILOT_DAILY_EVAL_SCHEDULE=0 19 * * *
AUTOPILOT_DAILY_EVAL_TIMEZONE=Asia/Seoul

# 자동 보고서 윤문(humanize). 'false' 면 OFF(기존 동작), 미설정 시 ON.
HUMANIZE_REPORTS_ENABLED=true
# Subconscious proactive engine — 상태 변화 감지 → LLM gate → proposal DM.
# SUBCONSCIOUS_ENABLED='true' + AUTOPILOT_OWNER_SLACK_USER_ID 설정 시 활성.
# 미설정/false → 비활성 (앱 부팅 영향 없음).
SUBCONSCIOUS_ENABLED=false
# (선택) tick BullMQ cron 표현식. 기본 '*/20 * * * *' (20분마다, Asia/Seoul).
SUBCONSCIOUS_SCHEDULE=*/20 * * * *
# (선택) 시간당 최대 proposal 건수 (슬라이딩 1시간 Redis 윈도우). 기본 4.
SUBCONSCIOUS_PROMOTION_BUDGET_PER_HOUR=4
# (선택) proposal DM 버튼 유효 시간 (ms). 기본 3600000 (1시간).
SUBCONSCIOUS_PROPOSAL_TTL_MS=3600000

# docs-sync-audit — 주간 문서↔코드 점검 (Layer1 결정론 + Layer2 codex 자기수정 루프)
# DOCS_AUDIT_ENABLED=false        # 'false' 면 task 전체 skip (미설정 시 활성)
# DOCS_AUDIT_MAX_FILES=5          # Layer2 점검 최대 SoT 파일 수 (codex 쿼터 가드)
# DOCS_AUDIT_MAX_ITERATIONS=3     # Layer2 자기수정 반복 캡
# AUTOPILOT_DOCS_SYNC_AUDIT_SCHEDULE=0 11 * * 0   # cron override (미설정 시 매주 일 11:00)
# AUTOPILOT_DOCS_SYNC_AUDIT_TIMEZONE=Asia/Seoul
