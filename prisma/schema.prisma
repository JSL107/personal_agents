// 이대리 (personal_agents) Prisma schema
// 기획서: jarvis_agents_plan_2026.md §11 참고

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model AgentRun {
  id            Int       @id @default(autoincrement())
  agentType     String    @map("agent_type")
  triggerType   String    @map("trigger_type")
  status        String
  modelUsed     String?   @map("model_used")
  // OPS-1 Quota Pane — 어떤 CLI provider 가 호출됐는지 (codex-cli / claude-cli / gemini-cli / mock)
  // 와 execute 시작~종료 elapsed 시간을 기록. /quota 슬래시가 provider 별 count + 평균 duration 산출.
  cliProvider   String?   @map("cli_provider")
  durationMs    Int?      @map("duration_ms")
  inputSnapshot Json      @map("input_snapshot")
  output        Json?
  startedAt     DateTime  @default(now()) @map("started_at")
  endedAt       DateTime? @map("ended_at")

  // V3 비전 봇 쪼개기 — Hierarchical Manager Pattern 의 handoff chain 추적용 self-relation.
  // (plan: docs/superpowers/plans/2026-05-07-agent-communication-topology.md §4.4 / §6.3)
  // Router 가 dispatch chain 안에서 worker → worker handoff 를 만들 때 parent.id 를 child 에 기록.
  // onDelete: SetNull — 부모가 삭제돼도 child 의 audit log 가치는 유지.
  // @@index([parentId]) 필수 — CEO 의 weekly handoff chain 조회 시 full scan 회피 (OMC architect 권장).
  parentId Int?       @map("parent_id")
  parent   AgentRun?  @relation("AgentRunHandoff", fields: [parentId], references: [id], onDelete: SetNull)
  children AgentRun[] @relation("AgentRunHandoff")

  evidenceRecords  EvidenceRecord[]
  dailyPlan        DailyPlan?
  prReviewOutcomes PrReviewOutcome[]
  careerProfiles   CareerProfile[]
  episodicMemories EpisodicMemory[]

  @@index([agentType, startedAt])
  @@index([parentId])
  @@map("agent_run")
}

model EvidenceRecord {
  id          Int       @id @default(autoincrement())
  agentRunId  Int?      @map("agent_run_id")
  agentRun    AgentRun? @relation(fields: [agentRunId], references: [id], onDelete: SetNull)
  sourceType  String    @map("source_type")
  sourceId    String    @map("source_id")
  url         String?
  title       String?
  excerpt     String?   @db.Text
  payload     Json
  collectedAt DateTime  @default(now()) @map("collected_at")

  @@index([sourceType, sourceId])
  @@map("evidence_record")
}

// PO-2 Preview Gate — Write-back 같은 외부 부작용 명령이 사용자 confirm 후에만 실행되도록 보장.
// SlackService 가 user-facing Block Kit 메시지에 ✅ apply / ❌ cancel 버튼을 노출 → 사용자가 클릭하면
// action_id (preview:apply / preview:cancel) 가 PreviewActionId 와 함께 들어와 PENDING → APPLIED/CANCELLED 전이.
// kind 별 strategy (PreviewApplier) 가 payload 를 해석해 실제 부작용 (Notion/GitHub write 등) 을 수행.
// expiresAt 이후 PENDING 인 row 는 EXPIRED 로 자연 만료 (별도 cron 스윕 가능 — 현재는 in-place 검증).
model PreviewAction {
  id          String    @id
  slackUserId String    @map("slack_user_id")
  kind        String
  payload     Json
  status      String
  // Slack interactivity payload 의 response_url — apply/cancel 후 원본 메시지를 update 하기 위해 보관.
  responseUrl String?   @map("response_url")
  // 생성 시점 사용자에게 보여진 "preview text" — apply 결과 메시지에서 다시 노출하기 위해 그대로 저장.
  previewText String    @map("preview_text") @db.Text
  expiresAt   DateTime  @map("expires_at")
  createdAt   DateTime  @default(now()) @map("created_at")
  appliedAt   DateTime? @map("applied_at")
  cancelledAt DateTime? @map("cancelled_at")

  @@index([slackUserId, status])
  @@map("preview_action")
}

// OPS-3 Slack Reaction → Inbox
// 사용자가 메시지에 configured emoji (기본 :raised_hand:) 를 달면 익일 /today 에 자동 흡수.
// slackUserId 는 reaction 을 단 사용자 — 이 사용자의 /today 만 해당 항목을 소비.
// 같은 메시지에 여러 사용자가 reaction 달면 각자 별도 inbox row 로 분리 (multi-user 격리).
model SlackInboxItem {
  id          Int       @id @default(autoincrement())
  slackUserId String    @map("slack_user_id")
  channelId   String    @map("channel_id")
  messageTs   String    @map("message_ts")
  text        String    @db.Text
  addedAt     DateTime  @default(now()) @map("added_at")
  consumed    Boolean   @default(false)
  consumedAt  DateTime? @map("consumed_at")

  @@unique([slackUserId, channelId, messageTs])
  @@index([slackUserId, consumed, addedAt])
  @@map("slack_inbox_item")
}

// jarvis_agents_plan_2026.md §11.1 daily_plan — "오늘 plan" 을 날짜 단위로 직접 조회할 수 있게 하는 뷰용 테이블.
// agent_run.output 에도 동일 정보가 있지만 plan_date 인덱스가 없어 날짜 기반 reporting 이 비효율.
// 같은 날 재실행 시 upsert 로 최신 plan 덮어쓰기 (planDate @unique).
model DailyPlan {
  id          Int      @id @default(autoincrement())
  planDate    DateTime @unique @map("plan_date") @db.Date
  planJson    Json     @map("plan_json")
  agentRunId  Int      @unique @map("agent_run_id")
  agentRun    AgentRun @relation(fields: [agentRunId], references: [id], onDelete: Cascade)
  evidenceIds Int[]    @map("evidence_ids")
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  @@map("daily_plan")
}

// QA-1 Reviewer 룰셋 학습 — /review-pr 결과에 사용자가 accept/reject 한 history 누적.
// 다음 /review-pr 프롬프트에 reject 된 코멘트 패턴을 negative example 로 1~2개 주입.
model PrReviewOutcome {
  id          Int      @id @default(autoincrement())
  agentRunId  Int      @map("agent_run_id")
  agentRun    AgentRun @relation(fields: [agentRunId], references: [id], onDelete: Cascade)
  slackUserId String   @map("slack_user_id")
  accepted    Boolean
  comment     String?  @db.Text
  createdAt   DateTime @default(now()) @map("created_at")

  @@index([slackUserId, accepted, createdAt])
  @@map("pr_review_outcome")
}

// 휴가 사용 내역 — 기간별 누적. slackUserId 는 확장키(현재 본인 1명).
// businessDays 는 등록 시점 계산값 저장 (규칙이 바뀌어도 과거 기록 불변, 감사·재현).
// canceledAt soft-cancel — 잔여 합산 시 NULL 만 포함.
model LeaveUsage {
  id           Int       @id @default(autoincrement())
  slackUserId  String    @map("slack_user_id")
  startDate    DateTime  @map("start_date") @db.Date
  endDate      DateTime  @map("end_date") @db.Date
  businessDays Float     @map("business_days")
  memo         String?
  canceledAt   DateTime? @map("canceled_at")
  createdAt    DateTime  @default(now()) @map("created_at")

  @@index([slackUserId, startDate])
  @@map("leave_usage")
}

model JobApplication {
  id             Int       @id @default(autoincrement())
  slackUserId    String    @map("slack_user_id")
  company        String
  role           String
  jdUrl          String?   @map("jd_url")
  status         String
  appliedAt      DateTime  @map("applied_at") @db.Date
  deadline       DateTime? @db.Date
  nextFollowUpAt DateTime? @map("next_follow_up_at") @db.Date
  notes          String?   @db.Text
  createdAt      DateTime  @default(now()) @map("created_at")
  updatedAt      DateTime  @updatedAt @map("updated_at")

  @@index([slackUserId, status])
  @@map("job_application")
}

model CareerProfile {
  id          Int       @id @default(autoincrement())
  agentRunId  Int?      @map("agent_run_id")
  agentRun    AgentRun? @relation(fields: [agentRunId], references: [id], onDelete: SetNull)
  slackUserId String    @map("slack_user_id")
  githubLogin String    @map("github_login")
  windowStart DateTime  @map("window_start") @db.Date
  prCount     Int       @map("pr_count")
  summary     String    @db.Text
  profileJson Json      @map("profile_json")
  createdAt   DateTime  @default(now()) @map("created_at")
  updatedAt   DateTime  @updatedAt @map("updated_at")

  @@index([slackUserId, createdAt])
  @@map("career_profile")
}

// Episodic Memory — AgentRun 완료 결과를 로컬 임베딩으로 시간축에 적재(spec 2026-06-18).
// embedding 은 pgvector 컬럼이라 Prisma 미지원 → Unsupported. 적재/검색은 $queryRaw 로만.
model EpisodicMemory {
  id           Int                         @id @default(autoincrement())
  kind         String // 'agent_run' | 'conversation' | 'manual' (1차는 'agent_run')
  agentRunId   Int?                        @map("agent_run_id")
  // onDelete: SetNull — AgentRun 삭제 시 dangling 대신 NULL 로(에피소드 audit 가치 유지).
  // FK 제약이 dangling 을 구조적으로 차단 → knowledge-lint 의 사후 L3 점검이 불요해짐(예방 > 점검).
  agentRun     AgentRun?                   @relation(fields: [agentRunId], references: [id], onDelete: SetNull)
  agentType    String?                     @map("agent_type")
  content      String                      @db.Text
  embedding    Unsupported("vector(384)")?
  occurredAt   DateTime                    @map("occurred_at")
  supersededAt DateTime?                   @map("superseded_at")
  createdAt    DateTime                    @default(now()) @map("created_at")

  @@index([kind, agentType, occurredAt])
  @@map("episodic_memory")
}
