// 이대리 (personal_agents) Prisma schema
// 기획서: jarvis_agents_plan_2026.md §11 참고

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model AgentRun {
  id                Int       @id @default(autoincrement())
  agentType         String    @map("agent_type")
  triggerType       String    @map("trigger_type")
  status            String
  modelUsed         String?   @map("model_used")
  // OPS-1 Quota Pane — 어떤 CLI provider 가 호출됐는지 (codex-cli / claude-cli / gemini-cli / mock)
  // 와 execute 시작~종료 elapsed 시간을 기록. /quota 슬래시가 provider 별 count + 평균 duration 산출.
  cliProvider       String?   @map("cli_provider")
  durationMs        Int?      @map("duration_ms")
  inputSnapshot     Json      @map("input_snapshot")
  output            Json?
  startedAt         DateTime  @default(now()) @map("started_at")
  endedAt           DateTime? @map("ended_at")

  evidenceRecords   EvidenceRecord[]
  dailyPlan         DailyPlan?

  @@index([agentType, startedAt])
  @@map("agent_run")
}

model EvidenceRecord {
  id           Int       @id @default(autoincrement())
  agentRunId   Int?      @map("agent_run_id")
  agentRun     AgentRun? @relation(fields: [agentRunId], references: [id], onDelete: SetNull)
  sourceType   String    @map("source_type")
  sourceId     String    @map("source_id")
  url          String?
  title        String?
  excerpt      String?   @db.Text
  payload      Json
  collectedAt  DateTime  @default(now()) @map("collected_at")

  @@index([sourceType, sourceId])
  @@map("evidence_record")
}

// jarvis_agents_plan_2026.md §11.1 daily_plan — "오늘 plan" 을 날짜 단위로 직접 조회할 수 있게 하는 뷰용 테이블.
// agent_run.output 에도 동일 정보가 있지만 plan_date 인덱스가 없어 날짜 기반 reporting 이 비효율.
// 같은 날 재실행 시 upsert 로 최신 plan 덮어쓰기 (planDate @unique).
model DailyPlan {
  id           Int      @id @default(autoincrement())
  planDate     DateTime @unique @db.Date @map("plan_date")
  planJson     Json     @map("plan_json")
  agentRunId   Int      @unique @map("agent_run_id")
  agentRun     AgentRun @relation(fields: [agentRunId], references: [id], onDelete: Cascade)
  evidenceIds  Int[]    @map("evidence_ids")
  createdAt    DateTime @default(now()) @map("created_at")
  updatedAt    DateTime @updatedAt @map("updated_at")

  @@map("daily_plan")
}
