{
  "name": "personal-agents",
  "version": "0.0.1",
  "description": "이대리 — Slack 기반 멀티 에이전트 업무 자동화 백엔드",
  "author": "",
  "private": true,
  "packageManager": "pnpm@9.15.9",
  "engines": {
    "node": ">=22"
  },
  "license": "UNLICENSED",
  "scripts": {
    "build": "nest build",
    "format": "prettier --write \"{src,test}/**/*.ts\"",
    "format:check": "prettier --check \"{src,test}/**/*.ts\"",
    "start": "nest start",
    "dev": "nest start --watch",
    "start:debug": "nest start --debug --watch",
    "start:prod": "node dist/main",
    "lint": "eslint \"{src,test}/**/*.ts\" --fix",
    "lint:check": "eslint \"{src,test}/**/*.ts\"",
    "check:env": "node scripts/check-env-sync.cjs",
    "docs:sync": "ts-node scripts/sync-docs.ts",
    "docs:check": "ts-node scripts/sync-docs.ts --check",
    "harness:replay": "ts-node scripts/harness-replay.ts",
    "test": "jest --testPathIgnorePatterns '/node_modules/' 'src/code-graph' && jest --workerIdleMemoryLimit=80MB src/code-graph",
    "test:watch": "jest --watch",
    "test:cov": "jest --coverage --workerIdleMemoryLimit=80MB",
    "test:debug": "node --inspect-brk -r tsconfig-paths/register -r ts-node/register node_modules/.bin/jest --runInBand",
    "test:e2e": "jest --config ./test/jest-e2e.json",
    "db:up": "docker compose up -d --wait postgres redis",
    "db:down": "docker compose down",
    "db:push": "prisma db push",
    "db:studio": "prisma studio",
    "prisma:generate": "prisma generate",
    "finlens": "node scripts/token-analyzer/server.mjs",
    "finlens:refresh": "TS_NODE_TRANSPILE_ONLY=1 NODE_OPTIONS=--max-old-space-size=4096 ts-node scripts/token-analyzer/analyze.ts"
  },
  "dependencies": {
    "@huggingface/transformers": "^4.2.0",
    "@nestjs/bullmq": "^11.0.4",
    "@nestjs/common": "^10.0.0",
    "@nestjs/config": "^4.0.4",
    "@nestjs/core": "^10.0.0",
    "@nestjs/platform-express": "^10.0.0",
    "@notionhq/client": "^2.3.0",
    "@octokit/rest": "^22.0.1",
    "@prisma/client": "^6.19.3",
    "@slack/bolt": "^4.7.0",
    "@slack/web-api": "^7.15.1",
    "bullmq": "^5.73.1",
    "cheerio": "^1.2.0",
    "class-transformer": "^0.5.1",
    "class-validator": "^0.15.1",
    "express": "^4.21.0",
    "ioredis": "^5.10.1",
    "puppeteer": "^24.40.0",
    "reflect-metadata": "^0.2.0",
    "rxjs": "^7.8.1",
    "tree-sitter": "^0.25.0",
    "tree-sitter-typescript": "^0.23.2",
    "ts-pattern": "^5.9.0"
  },
  "devDependencies": {
    "@nestjs/cli": "^10.0.0",
    "@nestjs/schematics": "^10.0.0",
    "@nestjs/testing": "^10.0.0",
    "@types/express": "^5.0.0",
    "@types/ioredis-mock": "^8.2.7",
    "@types/jest": "^29.5.2",
    "@types/node": "^20.3.1",
    "@types/supertest": "^6.0.0",
    "@typescript-eslint/eslint-plugin": "^8.0.0",
    "@typescript-eslint/parser": "^8.0.0",
    "eslint": "^8.0.0",
    "eslint-config-prettier": "^9.0.0",
    "eslint-plugin-prettier": "^5.0.0",
    "eslint-plugin-simple-import-sort": "^13.0.0",
    "ioredis-mock": "^8.13.1",
    "jest": "^29.5.0",
    "prettier": "^3.0.0",
    "prisma": "^6.19.3",
    "source-map-support": "^0.5.21",
    "supertest": "^7.0.0",
    "ts-jest": "^29.1.0",
    "ts-loader": "^9.4.3",
    "ts-node": "^10.9.1",
    "tsconfig-paths": "^4.2.0",
    "typescript": "^5.1.3"
  },
  "pnpm": {
    "overrides": {
      "multer": "^2.1.0",
      "form-data": "^4.0.6",
      "ws": "^8.21.0",
      "axios": "^1.16.0"
    }
  },
  "jest": {
    "moduleFileExtensions": [
      "js",
      "json",
      "ts"
    ],
    "rootDir": "src",
    "testRegex": ".*\\.spec\\.ts$",
    "transform": {
      "^.+\\.ts$": "ts-jest"
    },
    "collectCoverageFrom": [
      "**/*.(t|j)s"
    ],
    "coverageDirectory": "../coverage",
    "testEnvironment": "node",
    "setupFiles": [
      "<rootDir>/jest.polyfills.js"
    ]
  }
}
